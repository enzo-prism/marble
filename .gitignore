.swiftpm/
# App Store Connect working dir: ignore artifacts/screenshots/reports, but the
# export options ARE release configuration and must be in version control —
# without them `make asc-export` fails on a fresh clone.
.asc/*
!.asc/ExportOptions.plist
!.asc/UploadExportOptions.plist

# Node deps for the marketing composition
node_modules/

# Marketing composition caches — regenerable render/preview artifacts
marketing/**/.thumbnails/
marketing/**/.waveform-cache/
marketing/**/.hyperframes/
marketing/**/snapshots/

# Local scratch: verification screenshots, PR drafts, throwaway notes.
# Durable findings belong in WORKFLOW_PAPERCUTS.md, not here.
work/
