<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.healthkit</key>
	<true/>
	<!-- Order matters: the FIRST entry is the default access group for keychain
	     writes that don't name one. KeychainTokenStore (Strava OAuth) doesn't,
	     so Prism.marble must stay first or those tokens would silently start
	     landing in the shared group. The .shared group carries only the widget
	     snapshot, which always names its group explicitly. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)Prism.marble</string>
		<string>$(AppIdentifierPrefix)Prism.marble.shared</string>
	</array>
</dict>
</plist>
